# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used in Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://clapcheeks.tech

# API + AI service URLs
NEXT_PUBLIC_API_URL=https://api.clapcheeks.tech
NEXT_PUBLIC_AI_URL=https://ai.clapcheeks.tech

# Stripe (secret key + webhook — checkout uses Stripe lookup keys, not hardcoded price IDs)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email (Resend)
RESEND_API_KEY=re_...

# Cron job protection (generate a random secret)
CRON_SECRET=your-random-secret

# AI (server-side only — for coaching endpoint)
ANTHROPIC_API_KEY=optional-if-using-anthropic-fallback

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=clapcheeks-web
SENTRY_AUTH_TOKEN=sntrys_...

# Dev only
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
