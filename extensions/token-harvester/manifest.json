{
  "manifest_version": 3,
  "name": "Clapcheeks Token Harvester",
  "short_name": "Clapcheeks",
  "version": "0.1.1",
  "description": "Pushes dating-app auth tokens to your Clapcheeks daemon. Works on Tinder web (auto) and Bumble.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://tinder.com/*",
    "https://*.tinder.com/*",
    "https://api.gotinder.com/*",
    "https://hinge.co/*",
    "https://*.hinge.co/*",
    "https://*.hingeaws.net/*",
    "https://bumble.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://i.instagram.com/*",
    "https://*.clapcheeks.tech/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://tinder.com/*", "https://*.tinder.com/*"],
      "js": ["content_tinder.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hinge.co/*", "https://*.hinge.co/*"],
      "js": ["content_hinge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["content_instagram.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
